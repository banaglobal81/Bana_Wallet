{
  "permissions": {
    "allow": [
      "Bash(npm run dev:*)",
      "Bash(npm run server:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run preview:*)",
      "Bash(npm run clean:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(node server.js)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(npx playwright:*)",
      "Bash(bash start.sh)",
      "Bash(bash stop.sh)",
      "Bash(bash sync-harness-docs.sh)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(date:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(prisma db push:*)",
      "Bash(npx prisma db push:*)",
      "Read(.env)"
    ]
