// Prisma 7.x schema
// generator: uses the default "prisma-client-js" provider.
// In Prisma 7 the generator writes the client into node_modules/.prisma/client/,
// which @prisma/client re-exports at its package root — so
// `import { PrismaClient } from '@prisma/client'` works with no custom output path.
//
// PRISMA 7 BREAKING CHANGE: `url` is no longer valid in the datasource block.
// The connection URL is declared in prisma.config.ts (datasource.url = env("DATABASE_URL")).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED
}

// Platform-wide policy, a single row (id = "singleton"). Admin-configurable.
model PlatformSetting {
  id                    String   @id @default("singleton")
  // Only allow withdrawals to addresses saved in the user's address book.
  whitelistOnly         Boolean  @default(false)
  // Withdrawals valued under this USD amount auto-approve (skip the queue).
  // null/empty = every withdrawal requires manual approval.
  autoApproveUnderUsd   String?
  // Pause all withdrawals (incident / hub outage). Users see a banner.
  maintenanceMode       Boolean  @default(false)
  // Max total a single user can withdraw per rolling 24h (USD, stablecoins).
  dailyWithdrawalLimitUsd String?
  // Allow new user registration.
  signupsEnabled        Boolean  @default(true)
  // Platform identity shown to users.
  supportEmail          String?
  displayName           String?
  updatedAt             DateTime @updatedAt
}

// A user's saved/trusted withdrawal address (address book + whitelist).
model WithdrawalAddress {
  id        String   @id @default(cuid())
  userId    String
  label     String
  network   String
  address   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Immutable record of an admin action, for accountability / compliance.
model AuditLog {
  id         String   @id @default(cuid())
  adminId    String?  // admin who performed the action
  adminEmail String   // denormalized for display even if the admin is later removed
  action     String   // e.g. WITHDRAWAL_APPROVE, USER_ROLE_CHANGE, USER_DISABLE
  targetType String?  // e.g. user, withdrawal
  targetId   String?
  detail     String?  // short human-readable summary
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// A withdrawal held for admin review before it is forwarded to Nia-Hub.
// Funds only leave once an admin APPROVES (which forwards it to the hub).
model WithdrawalRequest {
  id              String           @id @default(cuid())
  userId          String           // BANA DB user id
  niaUserId       String           // Nia-Hub end-user id (used when forwarding)
  email           String           // denormalized for the admin queue
  currency        String
  network         String
  amount          String           // canonical decimal string (never a float)
  toAddress       String
  idempotencyKey  String?
  status          WithdrawalStatus @default(PENDING)
  reviewedById    String?          // admin who approved/rejected
  reviewedAt      DateTime?
  rejectionReason String?
  hubTxId         String?          // hub reference once forwarded
  lastError       String?
  createdAt       DateTime         @default(now())

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         Role     @default(USER)
  niaUserId    String?  @unique
  createdAt    DateTime @default(now())
  // Password-reset (forgot password) — only a HASH of the token is stored, never
  // the token itself, with a short expiry. Cleared on use.
  resetTokenHash   String?
  resetTokenExpiry DateTime?
  // Admin can disable an account — blocks login (compromised/abusive accounts).
  disabled     Boolean  @default(false)
}
