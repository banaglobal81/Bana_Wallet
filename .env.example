# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Nia-Hub B2B API (server-side ONLY — never exposed to the browser) ---
# Get these from the Nia-Hub Broker Dashboard after broker access is approved.
NIA_API_KEY="your-nia-api-key-public"
NIA_API_SECRET="your-nia-secret-key"
# Broker ID / Tenant ID issued by Nia-Hub.
NIA_BROKER_ID="your-nia-broker-id"
# Base URL of the Nia-Hub API (per the SPOT B2B docs).
NIA_BASE_URL="https://api.niawallet.com"
# Optional host override for the Bearer-token wallet-creation endpoint
# (POST /api/v1/address/create-smart-wallet). Leave empty to use NIA_BASE_URL.
NIA_HUB_URL=""
# Default end-user id to act for (B2B is multi-user; each call needs a userId).
NIA_DEFAULT_USER_ID=""
# Optional shared secret to verify inbound webhooks from Nia-Hub.
NIA_WEBHOOK_SECRET=""
# Port the backend listens on.
PORT="8787"

# --- Email (password-reset) ---
# Resend API key — required for the "Forgot password" flow to send reset emails.
# Get it from https://resend.com → API Keys. Without it, reset emails won't send
# (the request still succeeds silently so account existence is never revealed).
RESEND_API_KEY=""
# From address for outgoing email. The domain must be verified in Resend.
EMAIL_FROM="BANA Wallet <no-reply@yourdomain.com>"
