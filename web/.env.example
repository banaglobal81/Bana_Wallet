# ============================================================================
#  BANA Wallet — environment variables
#  Copy to .env for local dev. In production (Railway), set these in the
#  service's "Variables" tab. NEVER commit real secrets — .env is git-ignored.
# ============================================================================

# --- Database (REQUIRED) ---
# Local dev: your Postgres URL. On Railway: reference the Postgres plugin, i.e.
# set this to  ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/bana"

# --- Auth.js / NextAuth (REQUIRED) ---
# Session signing secret. Generate one with:  openssl rand -base64 32
AUTH_SECRET="generate-a-strong-random-32-char-secret"
# Public URL of the deployed app (used for reset links / callbacks).
# On Railway, set to the service domain, e.g. https://bana.up.railway.app
APP_URL="http://localhost:3000"

# --- First admin account (REQUIRED to seed) ---
# `npm run db:seed` creates/updates this user as an ADMIN. Use a STRONG password
# in production (do not reuse the local dev password).
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="set-a-strong-admin-password"

# --- Google sign-in (OPTIONAL — only if Google login is enabled) ---
# From Google Cloud Console → Credentials. Add the production redirect URI:
#   https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Nia-Hub B2B API (REQUIRED — server-side ONLY, never sent to the browser) ---
# From the Nia-Hub Broker Dashboard after broker access is approved.
NIA_API_KEY="your-nia-api-key"
NIA_API_SECRET="your-nia-secret-key"
NIA_BROKER_ID="your-nia-broker-id"
NIA_BASE_URL="https://api.niawallet.com"
# Optional host override for the Bearer wallet-creation endpoint. Empty = use NIA_BASE_URL.
NIA_HUB_URL=""
# Optional default end-user id (B2B is multi-user).
NIA_DEFAULT_USER_ID=""
# Optional shared secret to verify inbound webhooks from Nia-Hub.
NIA_WEBHOOK_SECRET=""

# --- Password-reset email via Resend (OPTIONAL — needed for "Forgot password") ---
# From https://resend.com → API Keys. The EMAIL_FROM domain must be verified.
RESEND_API_KEY=""
EMAIL_FROM="BANA Wallet <no-reply@yourdomain.com>"

# --- Gemini AI (OPTIONAL — only if AI features are used) ---
GEMINI_API_KEY=""

# --- Staking worker (daily accrual cron) ---
# Shared secret the worker sends in the `x-cron-secret` header to POST /api/cron/staking.
# Generate one with:  openssl rand -hex 32   (set the SAME value as the worker's secret)
CRON_SECRET=""

# --- Staking accelerated clock (TEST / DEMO ONLY — leave UNSET in production) ---
# Shortens "one staking day" so a full multi-day payout cycle can be observed in
# minutes. e.g. 300000 = 5 minutes per day. Set BOTH so the payout engine and the
# live display agree. In a demo env also run the settlement every few minutes
# (worker/cron on */5, or press "Run settlement now" in the admin staking page).
# UNSET / empty → a real 24h day (production behavior).
# STAKING_DAY_MS="300000"
# NEXT_PUBLIC_STAKING_DAY_MS="300000"

# --- MLM referral commission (대·소실적 매칭 + 유니레벨 부스트) ---
# OFF by default. Only "true" turns on the daily referral-commission payout that
# runs after the staking settlement. Keep OFF in production until the spec is
# finalized and legal/regulatory review is cleared.
# REFERRAL_BONUS_ENABLED="false"

# --- Cloudflare R2 (OPTIONAL — coin/brand logo uploads) — server-side only ---
# S3-compatible R2 credentials (Access Key ID + Secret), NOT a Cloudflare API token.
# Create them in Cloudflare dashboard → R2 → "Manage R2 API Tokens".
# ENDPOINT is the account URL WITHOUT the bucket; the bucket goes in R2_BUCKET_NAME.
R2_ENDPOINT="https://ab2cf04a8b240457302ac387f988f013.r2.cloudflarestorage.com"
R2_BUCKET_NAME="banawallet"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
